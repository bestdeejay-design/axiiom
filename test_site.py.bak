.icon-fail { color: var(--red); }
.icon-warn { color: var(--yellow); }
.icon-none { color: var(--text-dim); }

footer { margin-top: 40px; padding-top: 16px; border-top: 1px solid var(--border);
         font-size: 0.75rem; color: var(--text-dim); }
"""


def generate_report(all_pages, results_map, timestamp=None):
    if timestamp is None:
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    total = len(all_pages)
    all_checks = []
    for page in all_pages:
        all_checks.extend(results_map.get(page["rel"], []))
    passed = sum(1 for c in all_checks if c.status == Check.PASS)
    failed = sum(1 for c in all_checks if c.status == Check.FAIL)
    warned = sum(1 for c in all_checks if c.status == Check.WARN)

    cards_html = ""
    sitemap_html = ""
    sitemap_items = []

    for page in all_pages:
        checks = results_map.get(page["rel"], [])
        n_pass = sum(1 for c in checks if c.status == Check.PASS)
        n_fail = sum(1 for c in checks if c.status == Check.FAIL)
        n_warn = sum(1 for c in checks if c.status == Check.WARN)

        if n_fail > 0:
            card_class = "failed"
            worst = "fail"
        elif n_warn > 0:
            card_class = "warned"
            worst = "warn"
        else:
            card_class = "passed"
            worst = "pass"

        card_type = page["type"]
        checks_html = ""
        for c in checks:
            icon = {"pass": "✓", "fail": "✗", "warn": "△", "info": "i"}.get(c.status, "?")
            cls = c.status if c.status != "info" else "omit"
            detail = f'<span class="check-detail">— {c.detail[:120]}</span>' if c.detail else ""
            checks_html += f'<div class="check-item {cls}"><span class="check-icon">{icon}</span><span class="check-name">{c.name}</span> {detail}</div>'

        checks_block = f'<div class="card-checks" id="checks-{page["rel"].replace("/", "-").replace(".", "-")}">{checks_html}</div>'
        toggle = f'<button class="check-toggle" onclick="document.getElementById(\'checks-{page["rel"].replace("/", "-").replace(".", "-")}\').classList.toggle(\'open\')">▼ Details</button>'

        cards_html += f"""
        <div class="page-card {card_class}" data-type="{card_type}" data-status="{worst}">
            <div class="card-header">
                <div>
                    <div class="card-path">{page["url"]}</div>
                    <div class="card-title">{page.get("title", "")}</div>
                </div>
                <span class="card-type">{card_type}</span>
            </div>
            <div class="card-stats">
                <span class="card-stat pass">✓ {n_pass}</span>
                <span class="card-stat fail">✗ {n_fail}</span>
                <span class="card-stat warn">△ {n_warn}</span>
            </div>
            {toggle}
            {checks_block}
        </div>"""

        # Determine status for sitemap
        status_icon = {"pass": "●", "fail": "●", "warn": "●"}.get(worst, "○")
        status_class = {"pass": "icon-pass", "fail": "icon-fail", "warn": "icon-warn"}.get(worst, "icon-none")
        sitemap_items.append({
            "url": page["url"],
            "type": page["type"],
            "status": worst,
            "icon": status_icon,
            "cls": status_class,
        })

    # Build sitemap tree
    tree_groups = {}
    for item in sitemap_items:
        prefix = item["url"].rsplit("/", 1)[0] + "/" if "/" in item["url"].strip("/") else "/"
        if prefix not in tree_groups:
            tree_groups[prefix] = []
        tree_groups[prefix].append(item)

    for prefix in sorted(tree_groups.keys()):
        label = prefix if prefix != "/" else "root"
        items = tree_groups[prefix]
        sitemap_html += f'<div class="node"><span class="icon-none">▸</span> {label}</div>'
        for item in items:
            depth = item["url"].count("/")
            indent = "&nbsp;" * 4 * (depth - 1)
            name = item["url"].rsplit("/", 1)[-1] if "/" in item["url"].strip("/") else item["url"]
            sitemap_html += f'<div class="node"><span class="indent"></span><span class="{item["cls"]}">{item["icon"]}</span> {item["url"]} <span class="card-type">{item["type"]}</span></div>'

    filter_buttons = ""
    types = sorted(set(p["type"] for p in all_pages))
    filter_buttons += '<button class="filter-btn active" onclick="filterAll()">All</button>'
    for t in types:
        filter_buttons += f'<button class="filter-btn" onclick="filterType(\'{t}\')">{t}</button>'

    report = f"""<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AXIIOM Site Test Report</title>
<style>{REPORT_CSS}</style>
<script>
function filterType(type) {{
    document.querySelectorAll('.page-card').forEach(c => {{
        c.style.display = c.getAttribute('data-type') === type ? '' : 'none';
    }});
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');
}}
function filterAll() {{
    document.querySelectorAll('.page-card').forEach(c => c.style.display = '');
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    document.querySelector('.filter-btn').classList.add('active');
}}
function filterStatus(status) {{
    document.querySelectorAll('.page-card').forEach(c => {{
        c.style.display = c.getAttribute('data-status') === status ? '' : 'none';
    }});
}}
</script>
</head>
<body>
<h1>AXIIOM Site Test Report</h1>
<p class="subtitle">Generated {timestamp} — {total} pages, {len(all_checks)} checks</p>

<div class="summary">
    <div class="stat total"><span class="num">{total}</span><span class="lbl">Pages</span></div>
    <div class="stat pass"><span class="num">{passed}</span><span class="lbl">Passed</span></div>
    <div class="stat fail"><span class="num">{failed}</span><span class="lbl">Failed</span></div>
    <div class="stat warn"><span class="num">{warned}</span><span class="lbl">Warnings</span></div>
</div>

<h2>Filters</h2>
<div class="filters">{filter_buttons}</div>
<div class="filters" style="margin-top:-12px">
    <button class="filter-btn" onclick="filterStatus('fail')">🔴 Failed only</button>
    <button class="filter-btn" onclick="filterStatus('warn')">🟡 Warnings only</button>
    <button class="filter-btn" onclick="filterAll()">🟢 All pages</button>
</div>

<h2>Site Map</h2>
<div class="site-map"><div class="map-tree">{sitemap_html}</div></div>

<h2>Page Checks</h2>
<div class="page-grid">{cards_html}</div>

<footer>
    AXIIOM Site Validator — {timestamp}
</footer>
</body>
</html>"""
    return report


# ——————————————————————————————————————————————————————
# Main
# ——————————————————————————————————————————————————————
CHECKERS = [
    DocTypeChecker(),
    HtmlLangChecker(),
    CharsetChecker(),
    ViewportChecker(),
    MetaChecker(),
    TitleChecker(),
    CanonicalChecker(),
    RobotsChecker(),
    OGTagsChecker(),
    TwitterTagsChecker(),
    JsonLdChecker(),
    FontsChecker(),
    CssChecker(),
    FaviconChecker(),
    UiComponentsChecker(),
    ScriptsChecker(),
    AnalyticsChecker(),
    PageContentChecker(),
    BreadcrumbChecker(),
    LinkChecker(),
]


def run_checks(pages):
    results = {}
    for page in pages:
        page_checks = []
        for checker in CHECKERS:
            try:
                checks = checker.check(page, page["type"], all_pages=pages)
                page_checks.extend(checks)
            except Exception as e:
                page_checks.append(Check(Check.FAIL, f"{checker.name} threw: {e}"))
        results[page["rel"]] = page_checks
        # Extract title for display
        m = re.search(r'<title>(.*?)</title>', page["content"], re.DOTALL | re.IGNORECASE)
        page["title"] = m.group(1).strip() if m else ""
    return results


def main():
    parser = argparse.ArgumentParser(description="AXIIOM Site Validator")
    parser.add_argument("--dir", default=str(DEFAULT_DIR), help="Site root directory")
    parser.add_argument("--output", default=str(DEFAULT_OUTPUT), help="Output report path")
    parser.add_argument("--serve", action="store_true", help="Validate against live server")
    parser.add_argument("--exit-code", action="store_true", help="Exit with code 1 if any failures found")
    args = parser.parse_args()

    site_dir = Path(args.dir)
    if not site_dir.is_dir():
        print(f"Error: {site_dir} is not a directory", file=sys.stderr)
        sys.exit(1)

    print(f"🔍 Discovering pages in {site_dir}...")
    pages = discover_pages(site_dir)
    print(f"📄 Found {len(pages)} HTML pages")

    # Validate against live server if requested
    if args.serve:
        print(f"🌐 Fetching from {LIVE_URL}...")
        live_pages = []
        for page in pages:
            url = f"{LIVE_URL}{page['url']}"
            content = fetch_url(url)
            if content:
                page["content"] = content
                live_pages.append(page)
        print(f"🌐 Fetched {len(live_pages)} pages from live server")
        pages = live_pages

    print("✅ Running checks...")
    results = run_checks(pages)

    print("📊 Generating report...")
    report = generate_report(pages, results)
    output_path = Path(args.output)
    with open(output_path, "w") as f:
        f.write(report)
    print(f"📄 Report written to {output_path}")

    # Print summary
    all_checks = []
    for page in pages:
        all_checks.extend(results.get(page["rel"], []))
    passed = sum(1 for c in all_checks if c.status == Check.PASS)
    failed = sum(1 for c in all_checks if c.status == Check.FAIL)
    warned = sum(1 for c in all_checks if c.status == Check.WARN)
    print(f"\nSummary: {len(pages)} pages, {len(all_checks)} checks")
    print(f"  ✅ Passed: {passed}")
    print(f"  ❌ Failed: {failed}")
    print(f"  ⚠️  Warnings: {warned}")

    # Print failed checks
    if failed > 0:
        print("\n❌ Failures:")
        for page in pages:
            for c in results.get(page["rel"], []):
                if c.status == Check.FAIL:
                    print(f"  [{page['type']}] {page['url']}: {c.name} — {c.detail[:120]}")

    if warned > 0:
        print("\n⚠️ Warnings:")
        for page in pages:
            for c in results.get(page["rel"], []):
                if c.status == Check.WARN:
                    print(f"  [{page['type']}] {page['url']}: {c.name} — {c.detail[:120]}")

    if args.exit_code and failed > 0:
        sys.exit(1)


if __name__ == "__main__":
    main()
