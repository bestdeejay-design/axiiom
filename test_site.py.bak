.summary { display: flex; gap: 16px; margin: 20px 0 28px; flex-wrap: wrap; }
.stat { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
        padding: 16px 24px; min-width: 100px; text-align: center; }
.stat .num { font-size: 2rem; font-weight: 700; display: block; }
.stat .lbl { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: .05em; }
.stat.pass .num { color: var(--green); }
.stat.fail .num { color: var(--red); }
.stat.warn .num { color: var(--yellow); }
.stat.total .num { color: var(--blue); }

.filters { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
.filter-btn { background: var(--bg-card); border: 1px solid var(--border); color: var(--text);
              padding: 6px 14px; border-radius: 6px; cursor: pointer; font-size: 0.8rem; }
.filter-btn:hover { background: var(--bg-hover); }
.filter-btn.active { border-color: var(--blue); background: rgba(59,130,246,.15); }

.page-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
             gap: 16px; }
.page-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
             padding: 16px; transition: border-color .2s; }
.page-card:hover { border-color: var(--text-dim); }
.page-card.passed { border-left: 3px solid var(--green); }
.page-card.failed { border-left: 3px solid var(--red); }
.page-card.warned { border-left: 3px solid var(--yellow); }
.card-header { display: flex; justify-content: space-between; align-items: flex-start;
               margin-bottom: 8px; }
.card-path { font-size: 0.85rem; word-break: break-all; color: var(--blue); }
.card-title { font-size: 0.75rem; color: var(--text-dim); margin-bottom: 8px; }
.card-type { font-size: 0.7rem; background: rgba(59,130,246,.15); color: var(--blue);
             padding: 2px 8px; border-radius: 4px; }
.card-stats { display: flex; gap: 8px; margin: 8px 0; }
.card-stat { font-size: 0.75rem; padding: 2px 8px; border-radius: 4px; }
.card-stat.pass { background: rgba(34,197,94,.12); color: var(--green); }
.card-stat.fail { background: rgba(239,68,68,.12); color: var(--red); }
.card-stat.warn { background: rgba(234,179,8,.12); color: var(--yellow); }
.card-stat.omit { background: rgba(136,136,160,.12); color: var(--text-dim); }
.card-checks { max-height: 0; overflow: hidden; transition: max-height .3s ease; }
.card-checks.open { max-height: 2000px; }
.check-toggle { background: none; border: none; color: var(--text-dim); cursor: pointer;
                font-size: 0.75rem; padding: 4px 0; }
.check-toggle:hover { color: var(--text); }
.check-item { font-size: 0.78rem; padding: 3px 8px; margin: 2px 0; border-radius: 4px;
              display: flex; gap: 6px; align-items: center; }
.check-item.pass { background: rgba(34,197,94,.06); }
.check-item.fail { background: rgba(239,68,68,.06); }
.check-item.warn { background: rgba(234,179,8,.06); }
.check-item.omit { opacity: .5; }
.check-icon { flex-shrink: 0; width: 18px; text-align: center; }
.check-name  { font-weight: 500; }
.check-detail { color: var(--text-dim); }

.site-map { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
            padding: 20px; margin: 24px 0; }
.site-map h3 { margin-bottom: 12px; font-size: 1rem; }
.map-tree { font-family: monospace; font-size: 0.8rem; line-height: 1.8; }
.map-tree .node { display: flex; align-items: center; gap: 6px; }
.map-tree .indent { display: inline-block; width: 20px; }
