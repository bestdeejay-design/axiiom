#!/usr/bin/env python3
"""
test_site.py — AXIIOM site validator

Discovers all HTML pages in the project, validates common elements,
checks for inconsistencies, and generates a visual HTML report.

Usage:
    python3 test_site.py                          # validate local build
    python3 test_site.py --serve                  # validate against live nginx
    python3 test_site.py --dir /path/to/site      # custom path
    python3 test_site.py --output report.html      # custom output file
"""

import argparse
import json
import os
import re
import sys
import urllib.request
import urllib.error
from datetime import datetime
from pathlib import Path

# ——————————————————————————————————————————————————————
# Configuration
# ——————————————————————————————————————————————————————
SITE_ROOT = Path(__file__).resolve().parent
DEFAULT_DIR = SITE_ROOT
DEFAULT_OUTPUT = SITE_ROOT / "test-report.html"
LIVE_URL = "http://axiiom-dev.orb.local"

MINIMAL_TYPES = {"archive", "viz"}

PAGE_TYPES_DEF = {
    "landing":    {"paths": ["/index.html", "/index.htm"], "slug": "landing"},
    "industry":   {"prefix": "/industries/", "slug": "industry"},
    "tool":       {"prefix": "/tools/", "slug": "tool"},
    "tool-index": {"paths": ["/tools/index.html"], "slug": "tool-index"},
    "blog":       {"prefix": "/blog/", "slug": "blog"},
    "blog-index": {"paths": ["/blog/index.html"], "slug": "blog-index"},
    "docs":       {"prefix": "/docs/", "slug": "docs"},
    "demo-index": {"paths": ["/demo/app/index.html"], "slug": "demo-index"},
    "demo-sub":   {"prefix": "/demo/app/", "slug": "demo-sub"},
    "calculator": {"paths": ["/calculator/index.html"], "slug": "calculator"},
    "legal":      {"paths": ["/privacy/index.html", "/terms/index.html"], "slug": "legal"},
    "404":        {"paths": ["/404.html"], "slug": "404"},
    "archive":     {"prefix": "/archive/", "slug": "archive"},
    "archive-additional": {"prefix": "/docs/additional/", "slug": "archive"},
    "archive-docs": {"prefix": "/docs/archive/", "slug": "archive"},
    "archive-refs": {"prefix": "/docs/references/", "slug": "archive"},
    "viz":         {"paths": ["/docs/feature-map-viz/03-mindmap.html"], "slug": "viz"},
    "viz-index":   {"paths": ["/docs/feature-map-viz/index.html"], "slug": "viz"},
    "viz-old":     {"paths": ["/docs/feature-map.html"], "slug": "viz"},
    "viz-vis":     {"prefix": "/docs/visualizations/", "slug": "viz"},
}

# ——————————————————————————————————————————————————————
# Helpers
# ——————————————————————————————————————————————————————
def classify_page(rel_path):
    """Return page type slug based on relative path."""
    raw = "/" + rel_path.replace(os.sep, "/")
    for slug, defn in PAGE_TYPES_DEF.items():
        if "paths" in defn:
            for candidate in defn["paths"]:
                if raw == candidate:
                    return defn.get("slug", slug)
    # Strip index.html for prefix matching
    p = raw
    if p.endswith("/index.html"):
        p = p[: -len("index.html")]
    elif p.endswith(".html"):
        p = p.rsplit(".", 1)[0]
    prefix_defs = [(slug, defn) for slug, defn in PAGE_TYPES_DEF.items() if "prefix" in defn]
    prefix_defs.sort(key=lambda x: len(x[1]["prefix"]), reverse=True)
    for slug, defn in prefix_defs:
        if slug in ("demo-sub",) and p == defn["prefix"].rstrip("/"):
            continue
        if p.startswith(defn["prefix"]):
            return defn.get("slug", slug)
    return "other"


def read_file(path):
    try:
        with open(path, "rb") as f:
            return f.read().decode("utf-8", errors="replace")
    except Exception as e:
        return None


def fetch_url(url):
    try:
        resp = urllib.request.urlopen(url, timeout=10)
        return resp.read().decode("utf-8", errors="replace")
    except Exception:
        return None


def normalize_path(path):
    p = path.strip()
    if p.endswith("/index.html"):
        p = p[: -len("index.html")]
    if p.endswith("/"):
        p = p[:-1]
    if not p.startswith("/"):
        p = "/" + p
    return p if p != "" else "/"


# ——————————————————————————————————————————————————————
# Page discovery
# ——————————————————————————————————————————————————————
def discover_pages(directory, base_url=None):
    pages = []
    html_files = sorted(directory.rglob("*.html"))
    for fpath in html_files:
        if fpath.name == "test-report.html":
            continue
        rel = fpath.relative_to(directory).as_posix()
        content = read_file(str(fpath))
        if content is None:
            continue
        pages.append({
            "path": fpath,
            "rel": rel,
            "url": normalize_path(rel),
            "type": classify_page(rel),
            "content": content,
        })
    return pages


# ——————————————————————————————————————————————————————
# Check result types
# ——————————————————————————————————————————————————————
class Check:
    PASS = "pass"
    FAIL = "fail"
    WARN = "warn"
    INFO = "info"

    def __init__(self, status, name, detail=""):
        self.status = status
        self.name = name
        self.detail = detail

    def __repr__(self):
        return f"[{self.status}] {self.name}: {self.detail}"


# ——————————————————————————————————————————————————————
# Checker base
# ——————————————————————————————————————————————————————
class BaseChecker:
    """Base class for page checkers."""
    name = "base"
    description = ""

    def check(self, page, page_type, all_pages=None):
        """Return list of Check objects."""
        return []


# ——————————————————————————————————————————————————————
# HTML Structure checks
# ——————————————————————————————————————————————————————
class DocTypeChecker(BaseChecker):
    name = "DOCTYPE"
    description = "DOCTYPE declaration should be uppercase <!DOCTYPE html>"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "DOCTYPE: skipped for this page type")]
        results = []
        if re.search(r"<!DOCTYPE\s+html\s*>", content, re.IGNORECASE):
            if "<!DOCTYPE html>" in content:
                results.append(Check(Check.PASS, "DOCTYPE is correct"))
            else:
                m = re.search(r'<!DOCTYPE[^>]*>', content)
                results.append(Check(Check.PASS, f"DOCTYPE present: {m.group() if m else 'ok'} (lowercase is valid HTML5)"))
        else:
            results.append(Check(Check.FAIL, "DOCTYPE declaration missing"))
        return results


class HtmlLangChecker(BaseChecker):
    name = "html-lang"
    description = "<html> tag should have lang='ru'"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "html-lang: skipped for this page type")]
        m = re.search(r'<html\s[^>]*>', content, re.IGNORECASE)
        if not m:
            return [Check(Check.FAIL, "<html> tag not found")]
        tag = m.group()
        if 'lang="ru"' in tag:
            return [Check(Check.PASS, 'lang="ru" present')]
        m2 = re.search(r'lang="([^"]+)"', tag)
        if m2:
            return [Check(Check.FAIL, f'lang="{m2.group(1)}" — expected "ru"')]
        return [Check(Check.FAIL, "lang attribute missing on <html>")]


class CharsetChecker(BaseChecker):
    name = "charset"
    description = "Meta charset should be UTF-8"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "charset: skipped for this page type")]
        if re.search(r'<meta\s+charset\s*=\s*["\']?\s*UTF-8\s*["\']?\s*/?\s*>', content, re.IGNORECASE):
            return [Check(Check.PASS, "charset=UTF-8")]
        if re.search(r'<meta\s+charset\s*=', content, re.IGNORECASE):
            m = re.search(r'<meta\s+charset\s*=\s*["\']?([^"\'>\s]+)', content, re.IGNORECASE)
            return [Check(Check.FAIL, f'charset={m.group(1) if m else "found but not UTF-8"}')]
        return [Check(Check.FAIL, "charset meta tag missing")]


class ViewportChecker(BaseChecker):
    name = "viewport"
    description = "Viewport meta should be present"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "viewport: skipped for this page type")]
        m = re.search(r'<meta\s+name\s*=\s*["\']viewport["\'][^>]*>', content, re.IGNORECASE)
        if m:
            if 'user-scalable=no' in m.group():
                return [Check(Check.WARN, "viewport has user-scalable=no (demo sub-page only)")]
            return [Check(Check.PASS, "viewport meta present")]
        return [Check(Check.FAIL, "viewport meta missing")]


# ——————————————————————————————————————————————————————
# Meta / SEO checks
# ——————————————————————————————————————————————————————
class MetaChecker(BaseChecker):
    name = "meta-tags"
    description = "Essential meta tags"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "meta tags: skipped for this page type")]
        results = []
        checks = {
            "theme-color": r'<meta\s+name\s*=\s*["\']theme-color["\'][^>]*>',
            "description": r'<meta\s+name\s*=\s*["\']description["\'][^>]*>',
        }
        for tag, pattern in checks.items():
            if re.search(pattern, content, re.IGNORECASE):
                results.append(Check(Check.PASS, f"meta {tag} present"))
            else:
                results.append(Check(Check.WARN, f"meta {tag} missing"))
        return results


class TitleChecker(BaseChecker):
    name = "title"
    description = "Page title should be present and meaningful"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "title: skipped for this page type")]
        m = re.search(r'<title>(.*?)</title>', content, re.DOTALL | re.IGNORECASE)
        if not m:
            return [Check(Check.FAIL, "<title> missing")]
        title = m.group(1).strip()
        if not title:
            return [Check(Check.FAIL, "<title> is empty")]
        if title == "AXIIOM" or title == "AXIIOM | AXIIOM":
            return [Check(Check.WARN, f"title seems generic: '{title}'")]
        return [Check(Check.PASS, f"title: {title[:80]}...")]


class CanonicalChecker(BaseChecker):
    name = "canonical"
    description = "Canonical link should be present and match page URL"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "canonical: skipped for this page type")]
        m = re.search(r'<link\s+rel\s*=\s*["\']canonical["\'][^>]*href\s*=\s*["\']([^"\']+)["\']', content, re.IGNORECASE)
        if not m:
            return [Check(Check.FAIL, "canonical link missing")]
        href = m.group(1).rstrip("/")
        expected = f"https://axiiom.ru{page['url']}".rstrip("/")
        if href == expected:
            return [Check(Check.PASS, f"canonical: {m.group(1)}")]
        return [Check(Check.WARN, f"canonical: {m.group(1)} (expected {expected})")]


class RobotsChecker(BaseChecker):
    name = "robots"
    description = "noindex should only be on privacy/terms/404 pages"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "robots: skipped for this page type")]
        m = re.search(r'<meta\s+name\s*=\s*["\']robots["\'][^>]*content\s*=\s*["\']([^"\']+)["\']', content, re.IGNORECASE)
        noindex = m and "noindex" in m.group(1)
        should_noindex = page_type in ("legal", "404")
        if noindex and not should_noindex:
            return [Check(Check.FAIL, f"noindex on non-legal/404 page ({page_type})")]
        if should_noindex and not noindex:
            return [Check(Check.WARN, "noindex expected on this page type but missing")]
        if noindex:
            return [Check(Check.PASS, "noindex present (expected)")]
        return [Check(Check.PASS, "noindex not needed")]


class OGTagsChecker(BaseChecker):
    name = "og-tags"
    description = "Open Graph tags"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "OG tags: skipped for this page type")]
        required = ["og:title", "og:description", "og:url", "og:type", "og:image"]
        optional = ["og:locale", "og:site_name", "og:image:width", "og:image:height"]
        results = []
        for tag in required:
            pattern = rf'<meta\s+property\s*=\s*["\']{tag}["\'][^>]*>'
            if re.search(pattern, content, re.IGNORECASE):
                results.append(Check(Check.PASS, f"{tag} present"))
            else:
                results.append(Check(Check.FAIL, f"{tag} missing"))
        for tag in optional:
            if re.search(rf'<meta\s+property\s*=\s*["\']{tag}["\'][^>]*>', content, re.IGNORECASE):
                results.append(Check(Check.PASS, f"{tag} present"))
        return results


class TwitterTagsChecker(BaseChecker):
    name = "twitter-tags"
    description = "Twitter Card meta tags"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "Twitter tags: skipped for this page type")]
        required = ["twitter:card", "twitter:title", "twitter:description", "twitter:image"]
        results = []
        for tag in required:
            if re.search(rf'<meta\s+name\s*=\s*["\']{tag}["\'][^>]*>', content, re.IGNORECASE):
                results.append(Check(Check.PASS, f"{tag} present"))
            else:
                results.append(Check(Check.FAIL, f"{tag} missing"))
        return results


class JsonLdChecker(BaseChecker):
    name = "json-ld"
    description = "JSON-LD structured data"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in ("legal", "404", "demo-sub", "other") or page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "JSON-LD not required for this page type (skipped)")]
        if '<script type="application/ld+json">' in content:
            m = re.search(r'<script\s+type="application/ld\+json">(.*?)</script>', content, re.DOTALL)
            if m:
                try:
                    data = json.loads(m.group(1))
                    if "@graph" in data:
                        types = [item.get("@type", "") for item in data["@graph"]]
                        return [Check(Check.PASS, f"JSON-LD present: {', '.join(types)}")]
                    elif "@type" in data:
                        return [Check(Check.PASS, f"JSON-LD present: {data['@type']}")]
                    else:
                        return [Check(Check.PASS, "JSON-LD present")]
                except json.JSONDecodeError:
                    return [Check(Check.FAIL, "JSON-LD has invalid JSON")]
            return [Check(Check.PASS, "JSON-LD present")]
        return [Check(Check.WARN, "JSON-LD missing")]


# ——————————————————————————————————————————————————————
# Styles checks
# ——————————————————————————————————————————————————————
class FontsChecker(BaseChecker):
    name = "google-fonts"
    description = "Google Fonts preconnect/preload"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        results = []
        if page_type in ("demo-sub",) or page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "Google Fonts not required for this page type (skipped)")]
        if 'fonts.googleapis.com' in content:
            checks = [
                ("preconnect to fonts.googleapis.com", r'<link[^>]*rel\s*=\s*["\']preconnect["\'][^>]*fonts\.googleapis\.com'),
                ("preconnect to fonts.gstatic.com",  r'<link[^>]*rel\s*=\s*["\']preconnect["\'][^>]*fonts\.gstatic\.com'),
                ("preload Inter font",               r'<link[^>]*rel\s*=\s*["\']preload["\'][^>]*Inter'),
                ("Inter stylesheet",                  r'fonts\.googleapis\.com[^"\']*Inter[^"\']*display=swap'),
            ]
            for label, pattern in checks:
                if re.search(pattern, content, re.IGNORECASE):
                    results.append(Check(Check.PASS, label))
                else:
                    results.append(Check(Check.WARN, f"{label} missing"))
        else:
            results.append(Check(Check.WARN, "Google Fonts not referenced at all"))
        return results


class CssChecker(BaseChecker):
    name = "stylesheets"
    description = "Required stylesheets"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        results = []

        main_css = re.search(r'<link[^>]*rel\s*=\s*["\']stylesheet["\'][^>]*styles\.css', content, re.IGNORECASE)
        if main_css:
            if '/styles.css' in main_css.group() or 'href="styles.css"' in main_css.group():
                results.append(Check(Check.PASS, "styles.css linked"))
            else:
                results.append(Check(Check.PASS, "styles.css linked (relative path check)"))
        else:
            if page_type in ("demo-sub",) or page_type in MINIMAL_TYPES:
                results.append(Check(Check.PASS, "styles.css not required for this page type"))
            else:
                results.append(Check(Check.FAIL, "styles.css NOT linked"))

        if page_type in MINIMAL_TYPES:
            results.append(Check(Check.PASS, "preloader.css: skipped for this page type"))
            return results

        preloader_css = re.search(r'<link[^>]*rel\s*=\s*["\']stylesheet["\'][^>]*preloader\.css', content, re.IGNORECASE)
        has_preloader = '<div id="preloader"' in content
        if preloader_css:
            if has_preloader:
                results.append(Check(Check.PASS, "preloader.css linked"))
            else:
                results.append(Check(Check.WARN, "preloader.css linked but no preloader div"))
        else:
            if has_preloader:
                results.append(Check(Check.WARN, "preloader.css NOT linked but preloader div exists"))
            elif page_type == "docs":
                results.append(Check(Check.PASS, "preloader.css not needed (no preloader on docs pages)"))
            else:
                results.append(Check(Check.WARN, "preloader.css not linked"))

        # Page-specific stylesheets
        extra_css_map = {
            "docs": ("docs/styles.css", "/docs/styles.css"),
            "tool": ("tools/styles.css", "/tools/styles.css"),
            "tool-index": ("tools/index.css", "/tools/index.css"),
            "industry": None,
        }
        for ptype, css_refs in extra_css_map.items():
            if page_type == ptype and css_refs:
                found = any(re.search(rf'href=["\']/?{re.escape(css)}["\']', content) for css in (css_refs if isinstance(css_refs, tuple) else (css_refs,)))
                css_name = css_refs[0] if isinstance(css_refs, tuple) else css_refs
                if found:
                    results.append(Check(Check.PASS, f"{css_name} linked"))
                else:
                    results.append(Check(Check.WARN, f"{css_name} NOT linked"))

        return results


class FaviconChecker(BaseChecker):
    name = "favicon"
    description = "Favicon should be linked"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in ("demo-sub",) or page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "favicon not required for this page type (skipped)")]
        if re.search(r'<link[^>]*rel\s*=\s*["\'](?:icon|shortcut icon)["\'][^>]*>', content, re.IGNORECASE):
            return [Check(Check.PASS, "favicon linked")]
        return [Check(Check.WARN, "favicon not linked")]


# ——————————————————————————————————————————————————————
# UI Component checks
# ——————————————————————————————————————————————————————
class UiComponentsChecker(BaseChecker):
    name = "ui-components"
    description = "Common UI components should be present"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        results = []
        components = {
            "preloader":     r'<div\s+id\s*=\s*["\']preloader["\']',
            "noise overlay": r'<div\s+class\s*=\s*["\']noise["\']',
            "grid overlay":  r'<div\s+class\s*=\s*["\']grid-overlay["\']',
            "nav overlay":   r'<div\s+class\s*=\s*["\'].*?["\']\s+id\s*=\s*["\']navOverlay["\']',
            "mobile nav":    r'id\s*=\s*["\']mobileNav["\']',
            "header":        r'<header[^>]*id\s*=\s*["\']header["\']',
            "desktop nav":   r'id\s*=\s*["\']desktopNav["\']',
            "nav toggle":    r'id\s*=\s*["\']navToggle["\']',
            "footer":        r'<footer[^>]*class\s*=\s*["\'][^"\']*\bfooter\b[^"\']*["\']',
            "footer copy":   r'id\s*=\s*["\']footerCopy["\']',
            "breadcrumbs":   r'<nav[^>]*id\s*=\s*["\']breadcrumbs["\']',
            "CTA button":    r'id\s*=\s*["\']ctaBtn["\']',
        }

        skip_map = {
            "demo-sub": ["preloader", "noise overlay", "grid overlay", "nav overlay", "mobile nav",
                         "header", "desktop nav", "nav toggle", "footer", "footer copy", "breadcrumbs", "CTA button"],
            "docs": ["preloader"],
            "landing": ["breadcrumbs"],
            "404": ["footer", "footer copy", "breadcrumbs"],
        }
        for mt in MINIMAL_TYPES:
            skip_map[mt] = ["preloader", "noise overlay", "grid overlay", "nav overlay", "mobile nav",
                            "header", "desktop nav", "nav toggle", "footer", "footer copy", "breadcrumbs", "CTA button"]

        skipped = skip_map.get(page_type, [])

        for name, pattern in components.items():
            if name in skipped:
                results.append(Check(Check.PASS, f"{name}: skipped for {page_type}"))
                continue
            has = bool(re.search(pattern, content, re.IGNORECASE))
            if has:
                results.append(Check(Check.PASS, f"{name} present"))
            else:
                if name == "CTA button":
                    results.append(Check(Check.INFO, f"{name} not present (may be intentional)"))
                else:
                    results.append(Check(Check.FAIL, f"{name} MISSING"))

        return results


# ——————————————————————————————————————————————————————
# Script checks
# ——————————————————————————————————————————————————————
class ScriptsChecker(BaseChecker):
    name = "scripts"
    description = "Required JavaScript files should be loaded"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        results = []

        script_checks = {
            "/nav.js":      r'<script[^>]*src\s*=\s*["\']/?nav\.js["\'][^>]*>',
            "/theme.js":    r'<script[^>]*src\s*=\s*["\']/?theme\.js["\'][^>]*>',
            "/config.js":   r'<script[^>]*src\s*=\s*["\']/?config\.js["\'][^>]*>',
            "/preloader.js": r'<script[^>]*src\s*=\s*["\']/?preloader\.js["\'][^>]*>',
        }

        skip_map = {
            "demo-sub": ["/nav.js", "/theme.js", "/config.js"],
        }
        for mt in MINIMAL_TYPES:
            skip_map[mt] = ["/nav.js", "/theme.js", "/config.js", "/preloader.js"]

        skipped = skip_map.get(page_type, [])

        for script, pattern in script_checks.items():
            if script in skipped:
                results.append(Check(Check.PASS, f"{script}: skipped for {page_type}"))
                continue
            if re.search(pattern, content, re.IGNORECASE):
                results.append(Check(Check.PASS, f"{script} loaded"))
            else:
                results.append(Check(Check.WARN, f"{script} NOT loaded"))

        # Nav.init() call
        if page_type in ("demo-sub", "docs") or page_type in MINIMAL_TYPES:
            results.append(Check(Check.PASS, "Nav.init(): skipped for this page type"))
        else:
            nav_init = re.search(r'Nav\.init\(\s*\{([^}]*)\}\s*\)', content)
            if nav_init:
                params = "{" + nav_init.group(1) + "}"
                results.append(Check(Check.PASS, f"Nav.init() called with {params}"))
            else:
                results.append(Check(Check.FAIL, "Nav.init() NOT called"))

        return results


class AnalyticsChecker(BaseChecker):
    name = "analytics"
    description = "Analytics scripts should be present on most pages"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        results = []

        if page_type in ("demo-sub", "docs") or page_type in MINIMAL_TYPES:
            results.append(Check(Check.PASS, "analytics: skipped for this page type"))
        else:
            gtag_js = 'googletagmanager.com/gtag/js' in content
            gtag_call = 'gtag(' in content or 'gtagjs' in content
            if gtag_js:
                results.append(Check(Check.PASS, "Google Analytics (gtag.js) loaded"))
            else:
                results.append(Check(Check.WARN, "Google Analytics NOT loaded"))

            ym = 'mc.yandex.ru/metrika' in content
            if ym:
                results.append(Check(Check.PASS, "Yandex Metrika loaded"))
            else:
                results.append(Check(Check.WARN, "Yandex Metrika NOT loaded"))

        return results


# ——————————————————————————————————————————————————————
# Page-specific content checks
# ——————————————————————————————————————————————————————
class PageContentChecker(BaseChecker):
    name = "page-content"
    description = "Page-type-specific content sections"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        if page_type in MINIMAL_TYPES:
            return [Check(Check.PASS, "content: skipped for this page type")]
        results = []
        type_checks = {
            "landing":    [("hero section",        r'<header[^>]*class\s*=\s*["\']hero["\']'),
                           ("services section",    r'id\s*=\s*["\']services["\']'),
                           ("cases section",       r'id\s*=\s*["\']cases["\']'),
                           ("process section",     r'id\s*=\s*["\']process["\']'),
                           ("faq section",         r'id\s*=\s*["\']faq["\']')],
            "industry":   [("industries-hero",     r'industries-hero'),
                           ("main content",        r'<section\s+class\s*=\s*["\']section["\']')],
            "tool":       [("tool page",           r'tools-hero|tool-page')],
            "tool-index": [("tools-hero",          r'tools-hero')],
            "blog":       [("article-page",        r'article-page')],
            "blog-index": [("blog listing",        r'blog')],
            "other":      [("main content",        r'<main|<article|<section')],
            "docs":       [("docs content",       r'docs-article|<section')],
            "demo-index": [("demo catalog",        r'demo')],
            "demo-sub":   [("demo app wrapper",    r'app-content|app-header|bottom-nav|demo-page-hero|hero-content')],
            "calculator": [("calc-section",        r'calc-section')],
            "legal":      [("legal content",       r'class\s*=\s*["\']legal["\']')],
            "404":        [("error section",       r'class\s*=\s*["\']err["\']')],
        }

        checks = type_checks.get(page_type, [("main content", r'<main|<article|<section')])
        for label, pattern in checks:
            if re.search(pattern, content, re.IGNORECASE):
                results.append(Check(Check.PASS, f"content: {label}"))
            else:
                results.append(Check(Check.FAIL, f"missing: {label}"))

        return results


# ——————————————————————————————————————————————————————
# Breadcrumb checks
# ——————————————————————————————————————————————————————
class BreadcrumbChecker(BaseChecker):
    name = "breadcrumbs"
    description = "Breadcrumbs should be present or absent correctly"

    def check(self, page, page_type, all_pages=None):
        content = page["content"]
        results = []
        has_bc = '<nav class="breadcrumbs"' in content or 'id="breadcrumbs"' in content
        nav_init = re.search(r'Nav\.init\(\s*\{([^}]*)\}\s*\)', content)

        bc_setting = None
        if nav_init:
            m = re.search(r'breadcrumbs\s*:\s*(true|false)', nav_init.group(1))
            if m:
                bc_setting = m.group(1) == "true"

        should_have_bc = page_type not in ("landing", "404", "demo-sub", "other") and page_type not in MINIMAL_TYPES

        if has_bc and bc_setting is False:
            results.append(Check(Check.WARN, "breadcrumbs in HTML but Nav.init says breadcrumbs:false"))
        elif not has_bc and bc_setting is True:
            results.append(Check(Check.WARN, "breadcrumbs expected but not found in HTML"))
        elif not has_bc and should_have_bc and page_type != "landing":
            results.append(Check(Check.WARN, "no breadcrumbs for page type that typically has them"))
        else:
            results.append(Check(Check.PASS, "breadcrumbs state consistent"))

        # JSON-LD breadcrumbs
        if '<nav class="breadcrumbs" id="breadcrumbs"' in content:
            js_bc = re.search(r'<script\s+type="application/ld\+json">(.*?)</script>', content, re.DOTALL)
            if js_bc:
                try:
                    data = json.loads(js_bc.group(1))
                    if isinstance(data, dict):
                        graph = data.get("@graph", [data])
                        for item in graph:
                            if item.get("@type") == "BreadcrumbList":
                                items = item.get("itemListElement", [])
                                names = [i.get("name", "?") for i in items]
                                results.append(Check(Check.PASS, f"JSON-LD breadcrumbs: {' › '.join(names)}"))
                                break
                        else:
                            results.append(Check(Check.WARN, "JSON-LD present but no BreadcrumbList"))
                except (json.JSONDecodeError, KeyError):
                    results.append(Check(Check.WARN, "JSON-LD breadcrumb parse error"))

        return results


# ——————————————————————————————————————————————————————
# Internal link checker
# ——————————————————————————————————————————————————————
class LinkChecker(BaseChecker):
    name = "links"
    description = "Internal links should be valid"

    def check(self, page, page_type, all_pages=None):
        if all_pages is None or page_type in MINIMAL_TYPES:
            return []
        content = page["content"]
        results = []
        known_html = set()
        for p in all_pages:
            known_html.add(p["url"])
            if p["rel"].endswith("/index.html"):
                known_html.add(normalize_path(p["rel"][:-len("/index.html")]))
        known_html.add("/")
        known_html.update(["/privacy/", "/terms/", "/calculator/"])

        internal_links = set()
        for m in re.finditer(r'href\s*=\s*["\']([^"\']+)["\']', content):
            href = m.group(1)
            # Skip full URLs (external or canonical self-references)
            if re.match(r'https?://', href):
                continue
            if href.startswith("mailto:") or href.startswith("tel:") or href.startswith("javascript:"):
                continue
            # Skip pure hash links, data URIs
            if href.startswith("#") or href.startswith("data:"):
                continue
            internal_links.add(href)

        site_root = SITE_ROOT

        broken = []
        for link in sorted(internal_links):
            link_clean = link.split("#")[0].split("?")[0]
            if link_clean.startswith("//"):
                continue
            if link_clean.startswith("/"):
                lk = normalize_path(link_clean)
                if lk in known_html:
                    continue
                rel_path = link_clean.lstrip("/")
                resolved = site_root / rel_path
                if resolved.exists():
                    continue
                try:
                    from urllib.parse import unquote
                    decoded = unquote(rel_path)
                    if (site_root / decoded).exists():
                        continue
                except Exception:
                    pass
                broken.append(link)
            elif link_clean.startswith(".."):
                resolved = (Path(page["path"]).resolve().parent / link_clean).resolve()
                if resolved.exists():
                    continue
                try:
                    from urllib.parse import unquote
                    decoded = unquote(str(resolved))
                    if Path(decoded).exists():
                        continue
                except Exception:
                    pass
                broken.append(link)
            else:
                ext = Path(link_clean).suffix.lower()
                if ext not in (".html", ".css", ".js", ".svg", ".png", ".jpg",
                               ".jpeg", ".ico", ".json", ".xml", ".webp", ".webm", ".mp4", ""):
                    continue
                resolved = Path(page["path"]).resolve().parent / link_clean
                if not resolved.exists():
                    try:
                        from urllib.parse import unquote
                        decoded = unquote(str(resolved))
                        if Path(decoded).exists():
                            continue
                    except Exception:
                        pass
                    broken.append(link)

        if broken:
            detail = "; ".join(broken[:5])
            if len(broken) > 5:
                detail += f" ... +{len(broken) - 5} more"
            results.append(Check(Check.FAIL, f"{len(broken)} broken link(s): {detail}"))
        else:
            results.append(Check(Check.PASS, "no broken internal links found"))

        return results


# ——————————————————————————————————————————————————————
# Report generation
# ——————————————————————————————————————————————————————
REPORT_CSS = """
:root {
    --bg: #0a0a0f;
    --bg-card: #14141c;
    --bg-hover: #1c1c28;
    --border: #2a2a3a;
    --text: #e8e8ed;
    --text-dim: #8888a0;
    --green: #22c55e;
    --yellow: #eab308;
    --red: #ef4444;
    --blue: #3b82f6;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Inter', system-ui, sans-serif;
       background: var(--bg); color: var(--text); line-height: 1.6; padding: 24px; }
h1 { font-size: 1.8rem; margin-bottom: 4px; }
h2 { font-size: 1.2rem; margin: 24px 0 12px; color: var(--text-dim); }
